{
  "rewrites": [
    {
      "source": "/router-api/:path*",
      "destination": "/api/router-api/:path*"
    },
    {
      "source": "/router-api",
      "destination": "/api/router-api"
    }
  ],
  "functions": {
    "api/router-api.js": {
      "runtime": "nodejs20.x"
    },
    "api/router-api/[...path].js": {
      "runtime": "nodejs20.x"
    }
  }
}
